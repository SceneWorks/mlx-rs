+
+bool take_command_buffer_error(std::string& out) {
+  std::lock_guard<std::mutex> lk(g_cb_error_mtx);
+  if (!g_cb_error_set) {
+    return false;
+  }
+  out = g_cb_error_msg;
+  g_cb_error_msg.clear();
+  g_cb_error_set = false;
+  return true;
