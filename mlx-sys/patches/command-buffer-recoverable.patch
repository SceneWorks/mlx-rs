+// pmetal (sc-5009): a single slot for the first asynchronously-reported Metal
+// command-buffer error. Written from a Metal completion-handler thread, read
+// from the waiting (calling) thread, so it is mutex-guarded. We keep the FIRST
+// error until it is taken so a later failure can't mask the original cause.
+std::mutex g_cb_error_mtx;
+bool g_cb_error_set = false;
+std::string g_cb_error_msg;
+} // namespace
+
+void record_command_buffer_error(const std::string& msg) {
+  std::lock_guard<std::mutex> lk(g_cb_error_mtx);
+  if (!g_cb_error_set) {
+    g_cb_error_set = true;
+    g_cb_error_msg = msg;
+  }
